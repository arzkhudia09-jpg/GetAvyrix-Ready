# ============================================================
# AVYRIX DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in values for your environment

# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================

# Environment: "development" or "production"
# Controls security headers, CORS behavior, logging verbosity
ENVIRONMENT=production

# ============================================================
# API CONFIGURATION
# ============================================================

# API Base URL (required for frontend production builds)
# This tells the frontend where to reach the backend API
# Examples:
#   - https://api.avyrix.com (production)
#   - http://localhost:8000 (development)
#   - https://your-render-app.onrender.com (Render deployment)
API_BASE_URL=http://127.0.0.1:8000

# ============================================================
# CORS CONFIGURATION
# ============================================================

# Comma-separated list of allowed origins for CORS requests
# Default supports localhost development + Vercel/GitHub Pages production
# The backend also supports wildcard patterns for vercel.app and github.io
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-user.github.io

# ============================================================
# AI/OPENAI INTEGRATION (Optional)
# ============================================================

# OpenAI API Key (optional - scanner works without it)
# Set this only if you want AI-powered explanations
# If not set, scanner provides default security guidance
OPENAI_API_KEY=

# ============================================================
# SCANNER CONFIGURATION (Optional)
# ============================================================

# Semgrep scan timeout in seconds (default: 60)
SEMGREP_TIMEOUT=60

# ============================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default is INFO for production safety
LOG_LEVEL=INFO
